    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@fal-ai/client": "^1.9.5",
    "@vercel/analytics": "^2.0.1",
    "image-q": "^4.0.0",
    "jszip": "^3.10.1"
